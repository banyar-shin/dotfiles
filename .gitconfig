[user]
	name = banyar-shin
	email = banyar.minshin@gmail.com
[includeIf "gitdir:~/git-repos/ego/"]
	path = ~/git-repos/ego/.gitconfig
[core]
	editor = nvim
	autocrlf = input
	excludesfile = /Users/banyar/.gitignore_global
[commit]
	template = /Users/banyar/.stCommitMsg
[init]
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
